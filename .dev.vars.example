API_TOKEN=replace-with-a-long-random-string
YOUTUBE_API_KEY=replace-with-google-cloud-yt-data-api-key
# Optional. When set, tracklist page GETs route through Bright Data Web Unlocker.
# Leave unset for local dev from a residential IP (direct fetch works fine);
# required in prod on Cloudflare Workers (egress IPs are captcha-gated).
# BRIGHTDATA_API_KEY=

# Optional. When BOTH are set, tracklist GETs try a residential-IP forwarder
# (cloudflared → scripts/nas-fetch-proxy.mjs on a NAS) before falling back to
# BrightData. See README "Network strategy" for setup.
# HOME_PROXY_URL=https://tracked-proxy.example.com
# HOME_PROXY_TOKEN=replace-with-a-long-random-string

